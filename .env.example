# ──────────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────────
# Banco de dados (MySQL ou compatível)
# Exemplos:
#   Local Docker : mysql://root:senha@localhost:3306/licigov
#   PlanetScale  : mysql://user:pass@host/licigov?ssl={"rejectUnauthorized":true}
#   TiDB Cloud   : mysql://user:pass@host:4000/licigov?ssl={"rejectUnauthorized":true}
# ──────────────────────────────────────────────
DATABASE_URL=mysql://root:senha@localhost:3306/licigov

# ──────────────────────────────────────────────
# JWT — string aleatória longa (mín. 32 chars)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ──────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-longa-aqui

# ──────────────────────────────────────────────
# Google Gemini (IA)
# Obter em: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────
GEMINI_API_KEY=sua-chave-gemini-aqui

# ──────────────────────────────────────────────
# Variáveis legadas Manus — não são mais usadas
# após a Fase 2 do plano de recuperação.
# Deixe em branco ou remova depois da Fase 2.
# ──────────────────────────────────────────────
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
